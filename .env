# Server Configuration
PORT=3000

# Supabase Credentials
# Find these in Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-supabase-project-url.supabase.co
# Note: For backend actions (bypassing RLS policies safely), use the service_role key.
# For public client direct insert, the anon key is also usable, but server-side we recommend using the service_role key or public anon.
SUPABASE_KEY=your-supabase-service-role-key-or-anon-key

# Admin Configuration
# Set the credentials to restrict access to the Admin Dashboard (admin.html)
ADMIN_USERNAME=Ashwin
ADMIN_PASSWORD=admin@246

# MongoDB Configuration
# Connection URL for your local MongoDB database or MongoDB Atlas cluster.
# In case it is empty, the application will fallback to local json database storage.
MONGODB_URI=mongodb://localhost:27017/collegesite

# Security Settings
# Secret key used to sign and verify JWT session tokens.
JWT_SECRET=super_secret_jwt_key_ignitron

# Microsoft Outlook SMTP Email Configuration
# These are used to send auto-notifications when a student registers for an event.
# Outlook SMTP host is usually: smtp.office365.com or smtp-mail.outlook.com
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=ashwinantonyjose28@outlook.com
# For Microsoft Accounts with 2FA, create and use an App Password here.
EMAIL_PASS=your-outlook-email-password-or-app-password
ADMIN_EMAIL=ashwinantonyjose28@gmail.com
